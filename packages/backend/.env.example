# App Configuration
PORT=3001
NODE_ENV=development
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ICD-11 API Configuration
ICD11_API_BASE_URL=https://id.who.int/icd
ICD11_TOKEN_URL=https://icdaccessmanagement.who.int/connect/token
ICD11_CLIENT_ID=your_client_id
ICD11_CLIENT_SECRET=your_client_secret
ICD11_DEFAULT_LANGUAGE=en

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600
CACHE_KEY_PREFIX=icd11
