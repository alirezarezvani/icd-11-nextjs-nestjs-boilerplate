{
  "name": "create-icd11-app",
  "version": "1.0.0",
  "description": "A powerful CLI tool for generating customized ICD-11 healthcare applications with modern web technologies",
  "homepage": "https://github.com/your-org/icd11-nextjs-nestjs-boilerplate",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/icd11-nextjs-nestjs-boilerplate.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/your-org/icd11-nextjs-nestjs-boilerplate/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "create-icd11-app": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "templates/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run prepack",
    "pack:test": "npm pack --dry-run",
    "publish:beta": "npm publish --tag beta",
    "publish:latest": "npm publish"
  },
  "keywords": [
    "icd11",
    "healthcare",
    "medical-codes",
    "medical-coding",
    "who-api",
    "cli",
    "boilerplate",
    "scaffold",
    "generator",
    "nextjs",
    "nestjs",
    "typescript",
    "redis",
    "docker",
    "aws",
    "azure",
    "gcp",
    "cloud",
    "deployment",
    "cicd",
    "github-actions",
    "material-ui",
    "oauth2",
    "api-integration",
    "full-stack",
    "monorepo"
  ],
  "author": "ICD-11 Healthcare Boilerplate",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "validate-npm-package-name": "^5.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.10.0",
    "@types/validate-npm-package-name": "^4.0.2",
    "@types/jest": "^29.5.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}