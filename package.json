{
  "name": "icd11-search-application",
  "version": "1.0.0",
  "description": "ICD-11 Search Application with Next.js and NestJS",
  "private": true,
  "scripts": {
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:start": "cd frontend && npm run start",
    "backend:dev": "cd backend && npm run start:dev",
    "backend:build": "cd backend && npm run build",
    "backend:start": "cd backend && npm run start:prod",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "dev": "npm-run-all --parallel frontend:dev backend:dev",
    "build": "npm-run-all --parallel frontend:build backend:build",
    "start": "npm-run-all --parallel frontend:start backend:start",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
