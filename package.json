{
  "name": "icd11-healthcare-boilerplate",
  "version": "1.0.0",
  "description": "ICD-11 Healthcare Application Boilerplate with Next.js and NestJS",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "install:all": "npm install && npm run install:workspaces",
    "install:workspaces": "npm install --workspaces",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "dependencies": {
    "@byterover/cipher": "^0.2.2",
    "axios": "^1.11.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "packageManager": "npm@10.9.2"
}
